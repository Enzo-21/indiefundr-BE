# =============================================================================
# IndieFundr — Backend environment variables (Next.js)
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Never commit .env to git.
# =============================================================================

# --- Server ---
PORT=3000

# --- Database (MongoDB Atlas) ---
# Create a cluster at https://www.mongodb.com/cloud/atlas
# Database > Connect > Drivers > copy connection string
# URL-encode special characters in passwords (# becomes %23)
# Prisma uses DATABASE_URL (same value as MONGO_URI).
DATABASE_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/DATABASE?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/DATABASE?retryWrites=true&w=majority

# --- Auth ---
# Generate: openssl rand -base64 32
JWT_ACCESS_SECRET=your_random_access_jwt_secret_here
JWT_REFRESH_SECRET=your_random_refresh_secret_here
# Legacy alias (optional): JWT_SECRET is used as access secret if JWT_ACCESS_SECRET is unset
# JWT_SECRET=your_random_jwt_secret_here
ACCESS_TOKEN_TTL=1h
REFRESH_TOKEN_TTL_DAYS=30

# --- Admin (dashboard + treasury REST) ---
# Only this email can sign in at /admin/login (OTP via Resend)
ADMIN_ALLOWED_EMAIL=enzo21barrera@gmail.com
# REST /api/admin/treasury/* (external tools)
ADMIN_API_KEY=your_admin_api_key_here

# --- Mailing (Resend) ---
# https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here
# Verified sending domain in Resend (DNS records required)
MAILING_DOMAIN=indiefundr.com
# Optional: logo URL in OTP emails
MAILING_LOGO_URL=https://res.cloudinary.com/vectrals-cloudinary/image/upload/v1718580949/vpass/brand/icon-192x192-bg-white_b0chyw.png

# --- Cloudinary (profile photo uploads) ---
# https://console.cloudinary.com/ — only required if using photo routes
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Blockchain / Tron ---
# testnet = Shasta (development) | mainnet = production (real TRX/USDT)
BLOCKCHAIN_NETWORK=testnet

# TronGrid API hosts (defaults work for most setups)
TRON_TESTNET_FULL_HOST=https://api.shasta.trongrid.io
TRON_MAINNET_FULL_HOST=https://api.trongrid.io

# Optional: TronGrid API key for higher rate limits — https://www.trongrid.io/
TRON_API_KEY=

# USDT TRC20 contract addresses (defaults are official; only change if you know why)
USDT_TRC20_TESTNET_CONTRACT=TG3XXyExBkPp9nzdajDZsozEu4BkaSJozs
USDT_TRC20_MAINNET_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t

# Treasury wallet: receives seed payments, sends plant sale payouts
# Generate: node scripts/test-tron-client.js
# Fund on Shasta: https://shasta.tronex.io/ (TRX + test USDT)
TREASURY_ADDRESS=
TREASURY_PRIVATE_KEY=

# Fee sponsorship: treasury tops up TRX so users only need USDT to buy seeds
FEE_SPONSORSHIP_ENABLED=true
# Small TRX amount kept in user wallet after a recovery sweep to avoid dust-edge failures
SPONSOR_TRX_RESERVE=0.1
TREASURY_TRX_TOPUP_WAIT_MS=120000

# Wallet activation: treasury sends TRX on signup (off by default — lazy activate on first invest via fee sponsorship)
WALLET_ACTIVATION_ENABLED=false
# Minimum TRX transfer to activate new addresses (0.1 is typical; use 1 if needed on mainnet)
WALLET_ACTIVATION_TRX=0.1
WALLET_ACTIVATION_CONFIRM_TIMEOUT_MS=90000
MAX_WALLET_ACTIVATIONS_PER_DAY=500

# Wallet activity (on-chain history + status enrichment)
WALLET_ACTIVITY_LIMIT=50
# Last N TRC20 USDT transfers fetched live for the invest screen (chain read mode)
WALLET_ACTIVITY_CHAIN_LIMIT=30
# chain = network-first list enriched from DB; db = materialized WalletActivity only (rollback)
WALLET_ACTIVITY_READ_MODE=db
WALLET_ACTIVITY_STATUS_CONCURRENCY=4
WALLET_BALANCE_CACHE_TTL_MS=30000
WALLET_SYNC_BATCH_SIZE=20
WALLET_SYNC_STALE_MS=60000
# Max TRC20 rows fetched per full chain backfill; incremental sync uses min_timestamp after watermark
WALLET_CHAIN_SYNC_MAX_ROWS=2000
# Re-fetch chain txs this many ms before chainSyncedThroughAt to avoid missing late-indexed rows
WALLET_CHAIN_SYNC_OVERLAP_MS=600000

# On-chain transaction memos for reconciliation (see backend/docs/TRON_TRANSACTION_MEMO_RECONCILIATION.md)
# Format: INDIEFUNDR/<version>/<kind>/<fundId>/<entityId> — opaque order/investment ids only, never userId/email
INDIEFUNDR_CHAIN_MEMO_ENABLED=true
INDIEFUNDR_CHAIN_MEMO_VERSION=1
ADMIN_WALLET_STATS_CONCURRENCY=2

# TronGrid protection (server-side request throttling + retries)
TRON_HTTP_RPS_LIMIT=10
TRON_HTTP_BURST=2
TRON_HTTP_RETRY_MAX=3
TRON_HTTP_BASE_BACKOFF_MS=250
TRON_LIMITER_DIAGNOSTICS_ENABLED=false
# off | errors | info | debug
TRON_LIMITER_LOG_LEVEL=errors

# Admin treasury on-chain panel
TREASURY_ACTIVITY_LIMIT=50
# Warn on /admin/treasury when treasury TRX (network fuel) falls below this
TREASURY_MIN_TRX_BALANCE=50
# Log raw TronGrid rows + classification breakdown in server console
TREASURY_ONCHAIN_DEBUG=false
# Log ledger reconcile expected vs stored on admin treasury load
TREASURY_LEDGER_DEBUG=false
# Log raw Tron tx payloads during purchase-order processing / reconcile
PURCHASE_ORDER_TRON_DEBUG=false

# --- Revenue engine ---
REVENUE_ENGINE_ENABLED=true
INVESTMENT_AMOUNT_USDT=25
MIN_APP_MARGIN_USDT=40
APP_NET_REVENUE_PER_SUBSCRIBER_USDT=10
PAYOUT_LIQUIDITY_RESERVE_PER_SUBSCRIBER_USDT=3.3333333333333335
MIN_PLATFORM_MARGIN_PER_TRIAD_USDT=40

# Investment timing (duration strings: D days, W weeks, H hours, Mi minutes, Mo months)
# Defaults in src/lib/config/investmentTiming.ts if unset
# INVESTMENT_TERM=90D

# --- Referral recovery program ---
REFERRAL_INVITEE_BONUS_USDT=2
REFERRAL_INVITER_BONUS_USDT=2
REFERRAL_RECOVERY_PRINCIPAL_USDT=25
REFERRAL_RECOVERY_INVITEES_REQUIRED=2

# --- Optional ---
# Leave empty or use http://localhost:… for local dev. Login OTP is logged to the
# backend terminal only when NODE_ENV is not production and this host is localhost.
# Set LOG_LOGIN_OTP_TO_CONSOLE=false to disable that log.
FRONTEND_DOMAIN=

# Marketing site + Expo web app URLs
# Dev: landing at http://localhost:3000, app at http://localhost:8081 (Expo web)
# Prod: set APP_WEB_URL=https://app.yourdomain.com and MARKETING_DOMAIN=yourdomain.com
APP_WEB_URL=http://localhost:8081
MARKETING_DOMAIN=localhost:3000

# Firebase Admin — SERVER ONLY (never commit the JSON file or paste in frontend)
# Firebase Console → Project settings → Service accounts → Generate new private key
# Save as backend/secrets/firebase-sa.json
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-sa.json
