{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:indexes": "tsx scripts/ensure-mongo-indexes.ts",
    "db:seed": "prisma db seed",
    "db:verify": "tsx scripts/verify-prisma.ts",
    "db:setup": "npm run prisma:generate && npm run db:push && npm run db:indexes && npm run db:seed && npm run db:verify",
    "dev:init": "npm run db:setup && npm run dev",
    "cutover:smoke": "tsx scripts/cutover-smoke.ts",
    "audit:db-vs-chain": "tsx scripts/audit-db-vs-chain.ts",
    "heal:purchase-orders": "tsx scripts/heal-purchase-orders.ts",
    "backfill:referral-payout-orders": "tsx scripts/backfill-referral-payout-orders.ts",
    "backfill:unpaid-maturity-resolution": "tsx scripts/backfill-unpaid-maturity-resolution.ts",
    "backfill:usernames": "tsx scripts/backfill-usernames.ts",
    "resync:wallet-activity": "tsx scripts/resync-wallet-activity.ts",
    "cron:maturity": "tsx scripts/run-cron-maturity.ts",
    "test": "node --experimental-test-module-mocks --import tsx --test $(find src -name '*.test.ts' -print | sort)"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
