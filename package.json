    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^1.22.0",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "firebase-admin": "^13.10.0",
    "framer-motion": "^12.40.0",
    "jsonwebtoken": "^8.5.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^3.2.0",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
